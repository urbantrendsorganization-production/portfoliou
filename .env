# PostgreSQL
POSTGRES_DB=portfoliou
POSTGRES_USER=portfoliou_user
POSTGRES_PASSWORD=changeme_strong_password

# Django
SECRET_KEY=your-django-secret-key-here
DEBUG=0
ALLOWED_HOSTS=portfoliou.urbantrends.dev,localhost

# Database URL (used by Django)
DATABASE_URL=postgresql://portfoliou_user:changeme_strong_password@portfoliou-db:5432/portfoliou

# Redis
REDIS_URL=redis://redis:6379/0
